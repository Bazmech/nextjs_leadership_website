# =============================================================================
# ProductiveLeadership — environment variable template
# Copy to .env.local and fill in your values: cp .env.example .env.local
# =============================================================================

# -----------------------------------------------------------------------------
# Clerk authentication (required)
# Get keys: https://dashboard.clerk.com → API Keys
# Or run: npx clerk auth login && npx clerk env pull
# -----------------------------------------------------------------------------

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key
CLERK_SECRET_KEY=sk_test_your_secret_key

# Auth page paths
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Redirect after sign-in / sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FORCE_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FORCE_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# Legacy redirect vars (still supported by Clerk; keep in sync with FORCE URLs above)
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Redirect after sign-out
NEXT_PUBLIC_CLERK_AFTER_SIGN_OUT_URL=/

# Optional — Clerk webhooks (user.deleted → purge app user data)
# Dashboard → Webhooks → endpoint signing secret
# Endpoint URL: https://your-domain.com/api/webhooks/clerk
CLERK_WEBHOOK_SIGNING_SECRET=whsec_your_webhook_signing_secret

# -----------------------------------------------------------------------------
# Neon Postgres (required for database features)
# Vercel injects DATABASE_URL per deployment when Neon Storage is connected.
# Local: create a Neon branch per git branch — run: yarn db:branch
# -----------------------------------------------------------------------------

DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL_UNPOOLED=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# Legacy Postgres vars (optional; Neon Vercel integration may set these on deploy)
# POSTGRES_URL=
# POSTGRES_URL_NON_POOLING=
# PGHOST=
# PGHOST_UNPOOLED=
# PGUSER=
# PGDATABASE=
# PGPASSWORD=

# Optional — for Neon CLI branch management (yarn db:branch) and resolving
# friendly branch names on the dashboard (otherwise branch ID is shown)
# NEON_PROJECT_ID=your_neon_project_id
# NEON_API_KEY=your_neon_api_key

# -----------------------------------------------------------------------------
# Vercel (auto-injected on Vercel — do not set locally unless testing)
# -----------------------------------------------------------------------------
# VERCEL_ENV=development
# VERCEL_URL=
# VERCEL_PROJECT_PRODUCTION_URL=
# VERCEL_GIT_COMMIT_REF=

# -----------------------------------------------------------------------------
# Cookiebot CMP
# Loaded only when VERCEL_ENV=production and the project production host is
# www.productiveleadership.org (or productiveleadership.org). Local/preview skip it.
# Domain group ID lives in src/lib/cookiebot.js (public client value).
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Prismic CMS
# Create a repo: https://prismic.io/dashboard → Next.js → Connect your own web app
# Update repository name in slicemachine.config.json or set PRISMIC_REPOSITORY here
# -----------------------------------------------------------------------------

PRISMIC_REPOSITORY=productive-leadership

# Optional — required if your Prismic API is set to private
# PRISMIC_ACCESS_TOKEN=your_prismic_access_token

# Optional — secret for /api/revalidate webhook (set same value in Prismic webhook settings)
# PRISMIC_WEBHOOK_SECRET=your_webhook_secret
